{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedDeclarations": false
  },
  "include": [
    "*.cjs",
    "*.js",
    "*.mjs",
    "src/eslintConfig.ts",
    "src/index.ts",
    "src/semanticReleaseConfig.ts"
  ]
}
